# =============================================================
# LeanScan — repo-wide .gitignore
# =============================================================

# --- secrets / env (NEVER commit) ----------------------------
.env
.env.local
.env.*.local
coding/api/.env
coding/app/.env
# Keep example templates so contributors know what vars are needed
!.env.example
!**/.env.example

# --- macOS / editor junk -------------------------------------
.DS_Store
*.swp
*.swo
.~lock.*
.idea/
.vscode/*
!.vscode/settings.example.json
!.vscode/extensions.json

# --- dependencies --------------------------------------------
node_modules/
.pnpm-store/
.yarn/

# --- build / dist --------------------------------------------
dist/
build/
*.tsbuildinfo

# --- runtime / data ------------------------------------------
# User-uploaded meal photos — these are user content, not source code
coding/api/uploads/
# Local SQLite (if ever used)
*.sqlite
*.sqlite3
*.db

# --- logs / temp ---------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.tmp/
tmp/

# --- Expo / React Native -------------------------------------
coding/app/.expo/
coding/app/.expo-shared/
coding/app/web-build/
coding/app/dist/
coding/app/android/
coding/app/ios/
coding/app/*.jks
coding/app/*.p8
coding/app/*.p12
coding/app/*.key
coding/app/*.mobileprovision
coding/app/*.orig.*

# --- Prisma --------------------------------------------------
# Generated client is recreated by `prisma generate`; safe to ignore
coding/api/node_modules/.prisma/
coding/api/prisma/dev.db
coding/api/prisma/dev.db-journal

# --- Coverage / test outputs ---------------------------------
coverage/
.nyc_output/

# --- Docker / Compose runtime --------------------------------
docker-compose.override.yml
*.pid

# --- Misc binary outputs -------------------------------------
*.tgz
*.zip
*.tar.gz
