# Copy to .env (or .env.local) and fill in.
# Expo exposes env vars prefixed with EXPO_PUBLIC_ to the client at build time.

# API base URL.
# Local dev (Expo Go on phone, API in docker on your laptop):
#   Replace 192.168.1.42 with YOUR LAPTOP'S LAN IP — get it by running `ipconfig getifaddr en0` (macOS).
#   The phone must be on the same WiFi.
# iOS simulator can use http://localhost:3000
# Production (phase 7): https://api.leanscan.app
EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
