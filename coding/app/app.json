{
  "expo": {
    "name": "LeanScan",
    "slug": "leanscan",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "leanscan",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f1ea"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.leanscan.ios",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "LeanScan needs camera access so you can photograph your meals and track protein.",
        "NSPhotoLibraryUsageDescription": "LeanScan needs photo library access so you can attach existing meal photos.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "app.leanscan.android",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a3a2e"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "LeanScan accesses your photos to log meals.",
          "cameraPermission": "LeanScan needs camera access to scan meals."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3000"
    }
  }
}
