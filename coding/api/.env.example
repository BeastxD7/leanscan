# Copy to .env (in this directory) and fill in your own values.
# .env is gitignored.

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (Postgres)
# Local: docker-compose Postgres
DATABASE_URL=postgresql://leanscan:dev@postgres:5432/leanscan_dev?schema=public
# In production with Supabase Postgres + PgBouncer, set BOTH:
#   DATABASE_URL=<pooled URL with ?pgbouncer=true&connection_limit=1>
#   DIRECT_URL=<non-pooled URL — required by prisma migrate>
# DIRECT_URL=postgresql://...

# Local-filesystem storage for meal photos.
# Inside the container we mount this volume; on production we mount a Droplet volume.
UPLOADS_DIR=/app/uploads
UPLOADS_MAX_BYTES=10485760

# Auth
JWT_SECRET=replace-me-with-a-256-bit-random-string-locally
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_COST=12

# =============================================================
# AI vision provider
#
# Pick one: gemini | openai | azure-openai | bedrock
# Restart the API after changing.
# =============================================================
AI_PROVIDER=gemini

# ---- Gemini (default) ----
GEMINI_API_KEY=AIza-your-key-here
GEMINI_MODEL=gemini-2.0-flash

# ---- OpenAI (vanilla) ----
# Get key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Azure OpenAI ----
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=<your-vision-deployment-name>
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---- AWS Bedrock (Anthropic Claude) ----
# Make sure your account has been granted access to the model in the Bedrock console.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...    # only if using temporary credentials
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Email (Gmail SMTP via Nodemailer)
GMAIL_USER=shashankdevadiga2003@gmail.com
GMAIL_APP_PASSWORD=replace-with-16-char-app-password
EMAIL_FROM_NAME=LeanScan

# Admin bootstrap (creates the first admin on initial migrate)
ADMIN_BOOTSTRAP_EMAIL=shashankdevadiga2003@gmail.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-immediately

# CORS — comma-separated origins permitted to call the API in dev
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://*

# Credit system tuning
CREDITS_INITIAL_GRANT=100
CREDITS_ONBOARDING_BONUS=20
CREDITS_DAILY_REFILL=10
CREDITS_REFILL_CAP=50
